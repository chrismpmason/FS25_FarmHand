<?xml version="1.0" encoding="utf-8" standalone="no"?>
<modDesc descVersion="105">
    <author>Chris Mason</author>
    <version>0.2.0.0</version>

    <title>
        <en>FarmHand</en>
    </title>

    <description>
        <en><![CDATA[Hire farm hands and grow them into a capable workforce.

New hands start near-useless: they wear equipment hard and can only handle basic
tasks. Two separate paths make them better. Experience builds automatically from
the work they do and steadily reduces the wear, fuel and time they cost you.
Formal on-the-job courses unlock what they are allowed to do at all — a hand
cannot touch the sprayer until he has earned his pesticides certificate.

Wages are paid every month, and a well-trained hand who is underpaid may walk.
Decide who is worth keeping.]]></en>
    </description>

    <iconFilename>icon_FarmHand.dds</iconFilename>

    <multiplayer supported="false"/>

    <extraSourceFiles>
        <sourceFile filename="scripts/FarmHand.lua"/>
    </extraSourceFiles>

    <actions>
        <action name="FARMHAND_OPEN" axisType="HALF"/>
        <!-- TEMP (build-2 sub-slice 1): open the full-screen shell; removed when K is swapped over. -->
        <action name="FARMHAND_SHELL" axisType="HALF"/>
    </actions>

    <inputBinding>
        <actionBinding action="FARMHAND_OPEN">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_k"/>
        </actionBinding>
        <!-- TEMP (build-2 sub-slice 1): full-screen shell on J, separate from K. -->
        <actionBinding action="FARMHAND_SHELL">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_j"/>
        </actionBinding>
    </inputBinding>

    <l10n>
        <text name="farmhand_ui_title">
            <en>Farm Hands</en>
        </text>
        <text name="farmhand_ui_certs_none">
            <en>No certificates</en>
        </text>
        <text name="farmhand_ui_active">
            <en>[ACTIVE]</en>
        </text>
        <text name="farmhand_ui_view_hire">
            <en>Hire</en>
        </text>
        <text name="farmhand_ui_view_hands">
            <en>Farm Hands</en>
        </text>
        <text name="farmhand_ui_available">
            <en>Available</en>
        </text>
        <text name="farmhand_ui_no_candidates">
            <en>No candidates this month</en>
        </text>
        <text name="input_FARMHAND_OPEN">
            <en>Farm Hands panel</en>
        </text>
        <text name="input_FARMHAND_SHELL">
            <en>Farm Hands shell (WIP)</en>
        </text>
    </l10n>
</modDesc>
